# Copiá a .env.local y completá valores (no commitear .env.local)
#
# IMPORTANTE: los nombres tienen que ser EXACTAMENTE estos (incluye NEXT_PUBLIC_).
# Sin NEXT_PUBLIC_ Next no expone la variable al navegador y isSupabaseConfigured() falla.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Twilio WhatsApp (solo servidor — SIN prefijo NEXT_PUBLIC_)
# Sin credenciales, POST /api/booking/whatsapp responde 503. Reiniciá el dev server tras editar.
# Podés usar ACCOUNT_SID, API_KEY_SID, API_KEY_SECRET como en Flutter.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_WHATSAPP_FROM=whatsapp:+5491125303794

# Plantillas (Content SID). Por defecto ya están en código; solo definí env si cambiás de plantilla.
# Cliente: reunión agendada. Admin: aviso de nueva reserva.
# TWILIO_WHATSAPP_TEMPLATE_CLIENT_SID=HXdf3be6b2533d658ad6cfbb2c2e42fc29
# TWILIO_WHATSAPP_TEMPLATE_ADMIN_SID=HX9b3ff8e1cc483e1680cfbed7d52af258

# Opcional: legacy un solo template → se usa solo para el mensaje al cliente
# TWILIO_WHATSAPP_TEMPLATE_SID=

# A quién avisar por WhatsApp (E.164, ej +54911...). Si no va, usa WHATSAPP_NUMBER del sitio.
# TWILIO_WHATSAPP_ADMIN_TO=

# Si la plantilla admin tiene {{3}} nombre y {{4}} tel: TWILIO_ADMIN_TEMPLATE_EXTENDED=1
# TWILIO_ADMIN_TEMPLATE_EXTENDED=1

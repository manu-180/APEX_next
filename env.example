# Copiá a .env.local y completá valores (no commitear .env.local)
#
# IMPORTANTE: los nombres tienen que ser EXACTAMENTE estos (incluye NEXT_PUBLIC_).
# Sin NEXT_PUBLIC_ Next no expone la variable al navegador y isSupabaseConfigured() falla.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Bridge de reservas → apex-leads (dueño de Evolution API + inbox WhatsApp)
# El secret es el mismo CRON_SECRET configurado en el proyecto apex-leads.
APEX_LEADS_URL=https://leads.theapexweb.com
APEX_LEADS_BOOKING_SECRET=

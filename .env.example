# URL pública del sitio (Vercel / producción)
# NEXT_PUBLIC_APP_URL=https://www.theapexweb.com

# Google Analytics 4 — ID de medición (G-XXXXXXXX). Sin valor, no se carga GA.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-TK45RZGM4F

# Sentry DSN — Error tracking. Sin valor, Sentry está deshabilitado.
# NEXT_PUBLIC_SENTRY_DSN=https://[key]@[domain].ingest.sentry.io/[projectId]

# PostHog API — Product analytics & events. Sin valor, PostHog está deshabilitado.
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_xxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
